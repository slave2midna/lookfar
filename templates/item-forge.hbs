{{!-- modules/lookfar/templates/item-forge.hbs --}}

<div id="if-body">
  <div class="lf-if-form">
    <div class="lf-if-layout">

      {{!-- Left Column: Item selection, preview, attributes --}}
      <div class="lf-if-col-left">

        {{!-- Choose Item --}}
        <fieldset class="lf-if-fieldset">
          <legend>{{localize "LOOKFAR.ItemForge.Dialogs.ItemForge.ChooseItem.Legend"}}</legend>
          <div class="lf-if-choose-item">
            <div class="lf-if-item-types">
              <label>
                <input type="radio" name="itemType" value="weapon" checked>
                {{localize "LOOKFAR.ItemForge.Dialogs.ItemForge.ChooseItem.Weapon"}}
              </label><br>
              <label>
                <input type="radio" name="itemType" value="armor">
                {{localize "LOOKFAR.ItemForge.Dialogs.ItemForge.ChooseItem.Armor"}}
              </label><br>
              <label>
                <input type="radio" name="itemType" value="shield">
                {{localize "LOOKFAR.ItemForge.Dialogs.ItemForge.ChooseItem.Shield"}}
              </label><br>
              <label>
                <input type="radio" name="itemType" value="accessory">
                {{localize "LOOKFAR.ItemForge.Dialogs.ItemForge.ChooseItem.Accessory"}}
              </label>
            </div>

            <div class="lf-if-template-wrapper">
              <div id="templateList" class="lf-if-scroll lf-if-template-list">
              </div>
            </div>
          </div>
        </fieldset>

        {{!-- Preview --}}
        <fieldset class="lf-if-fieldset">
          <legend>{{localize "LOOKFAR.ItemForge.Dialogs.ItemForge.Preview.Legend"}}</legend>
          <div id="itemPreviewLarge" class="lf-if-preview"></div>
        </fieldset>

        {{!-- Attributes --}}
        <div id="attrRow" class="lf-if-attr-row">
          <fieldset class="lf-if-fieldset">
            <legend>{{localize "LOOKFAR.ItemForge.Dialogs.ItemForge.Attributes.Legend"}}</legend>

            <div id="attrInner" class="lf-if-attr-inner">
              <span class="lf-if-attr-bracket">(</span>

              <select id="optAttrA" class="lf-if-select-medium">
                <option value="MIG">{{localize "LOOKFAR.Terms.Attributes.MIG"}}</option>
                <option value="DEX">{{localize "LOOKFAR.Terms.Attributes.DEX"}}</option>
                <option value="INS">{{localize "LOOKFAR.Terms.Attributes.INS"}}</option>
                <option value="WLP">{{localize "LOOKFAR.Terms.Attributes.WLP"}}</option>
              </select>

              <span class="lf-if-attr-plus">+</span>

              <select id="optAttrB" class="lf-if-select-medium">
                <option value="MIG">{{localize "LOOKFAR.Terms.Attributes.MIG"}}</option>
                <option value="DEX">{{localize "LOOKFAR.Terms.Attributes.DEX"}}</option>
                <option value="INS">{{localize "LOOKFAR.Terms.Attributes.INS"}}</option>
                <option value="WLP">{{localize "LOOKFAR.Terms.Attributes.WLP"}}</option>
              </select>

              <span class="lf-if-attr-bracket">)</span>
            </div>
          </fieldset>
        </div>

      </div>

      {{!-- Right Column: Customize, qualities, cost --}}
      <div class="lf-if-col-right">

        {{!-- Customize --}}
        <fieldset class="lf-if-fieldset">
          <legend>{{localize "LOOKFAR.ItemForge.Dialogs.ItemForge.Customize.Legend"}}</legend>

          <div id="customizeArea" class="lf-if-customize">

            {{!-- Weapon-only customize options --}}
            <div id="weaponCustomize" class="lf-if-weapon-customize">

              <label>
                <input type="checkbox" id="optPlusOne">
                <span>{{localize "LOOKFAR.ItemForge.Dialogs.ItemForge.Customize.PlusOneAccuracy"}}</span>
              </label>

              <label>
                <input type="checkbox" id="optPlusDamage">
                <span>{{localize "LOOKFAR.ItemForge.Dialogs.ItemForge.Customize.PlusFourDamage"}}</span>
              </label>

              <label id="handToggleWrap" class="lf-if-hand-toggle">
                <input type="checkbox" id="optToggleHand">
                <span id="handToggleLabel"></span>
              </label>

              <label>
                {{localize "LOOKFAR.ItemForge.Dialogs.ItemForge.Customize.Element"}}
                <select id="optElement" class="lf-if-select-medium">
                  <option value="physical" selected>{{localize "LOOKFAR.Terms.Element.Physical"}}</option>
                  <option value="fire">{{localize "LOOKFAR.Terms.Element.Fire"}}</option>
                  <option value="ice">{{localize "LOOKFAR.Terms.Element.Ice"}}</option>
                  <option value="earth">{{localize "LOOKFAR.Terms.Element.Earth"}}</option>
                  <option value="air">{{localize "LOOKFAR.Terms.Element.Air"}}</option>
                  <option value="bolt">{{localize "LOOKFAR.Terms.Element.Bolt"}}</option>
                  <option value="dark">{{localize "LOOKFAR.Terms.Element.Dark"}}</option>
                  <option value="light">{{localize "LOOKFAR.Terms.Element.Light"}}</option>
                  <option value="poison">{{localize "LOOKFAR.Terms.Element.Poison"}}</option>
                </select>
              </label>

            </div>

            {{!-- Non-weapon fallback --}}
            <div id="noCustomize" class="lf-if-no-customize">
              {{localize "LOOKFAR.ItemForge.Dialogs.ItemForge.Customize.NoOptions"}}
            </div>

          </div>
        </fieldset>

        {{!-- Qualities --}}
        <fieldset class="lf-if-fieldset">
          <legend>{{localize "LOOKFAR.ItemForge.Dialogs.ItemForge.Qualities.Legend"}}</legend>

          <div class="lf-if-qualities-select">
            <select id="qualitiesCategory" class="lf-if-select-full">
              <option value="none" selected>{{localize "LOOKFAR.ItemForge.Dialogs.ItemForge.Qualities.Options.None"}}</option>
              <option value="basic">{{localize "LOOKFAR.ItemForge.Dialogs.ItemForge.Qualities.Options.Basic"}}</option>
              <option value="custom">{{localize "LOOKFAR.ItemForge.Dialogs.ItemForge.Qualities.Options.Custom"}}</option>

              {{!-- Origin-based categories map to Terms.Origin.* --}}
              <option value="ardent">{{localize "LOOKFAR.Terms.Origin.Ardent"}}</option>
              <option value="aerial">{{localize "LOOKFAR.Terms.Origin.Aerial"}}</option>
              <option value="thunderous">{{localize "LOOKFAR.Terms.Origin.Thunderous"}}</option>
              <option value="paradox">{{localize "LOOKFAR.Terms.Origin.Paradox"}}</option>
              <option value="terrestrial">{{localize "LOOKFAR.Terms.Origin.Terrestrial"}}</option>
              <option value="glacial">{{localize "LOOKFAR.Terms.Origin.Glacial"}}</option>
              <option value="spiritual">{{localize "LOOKFAR.Terms.Origin.Spiritual"}}</option>
              <option value="corrupted">{{localize "LOOKFAR.Terms.Origin.Corrupted"}}</option>
              <option value="aquatic">{{localize "LOOKFAR.Terms.Origin.Aquatic"}}</option>
              <option value="mechanical">{{localize "LOOKFAR.Terms.Origin.Mechanical"}}</option>
            </select>
          </div>

          <div id="qualitiesList" class="lf-if-scroll lf-if-qualities-list">

            {{!-- STANDARD QUALITY LIST --}}
            <div id="qualitiesStandardBlock"></div>

            {{!-- CUSTOM QUALITY BLOCK --}}
            <div id="qualitiesCustomBlock" class="lf-if-qualities-custom-block">

              <textarea
                id="customEffect"
                rows="2"
                wrap="soft"
                class="lf-if-custom-effect"
                title="{{localize "LOOKFAR.ItemForge.Dialogs.ItemForge.Qualities.Custom.Tooltip.Effect"}}"></textarea>

              <div class="lf-if-custom-cost-row">
                <label for="customCost" class="lf-if-custom-cost-label">
                  {{localize "LOOKFAR.ItemForge.Dialogs.ItemForge.Qualities.Custom.CostLabel"}}
                </label>
                <input
                  id="customCost"
                  type="number"
                  min="0"
                  step="1"
                  inputmode="numeric"
                  pattern="\\d*"
                  value="0"
                  class="lf-if-custom-cost-input"
                  title="{{localize "LOOKFAR.ItemForge.Dialogs.ItemForge.Qualities.Custom.Tooltip.Cost"}}">
              </div>

              <button type="button" id="customApply" class="lf-if-custom-apply">
                {{localize "LOOKFAR.ItemForge.Dialogs.ItemForge.Qualities.Custom.Button"}}
              </button>

            </div>

          </div>
        </fieldset>

        {{!-- Cost --}}
        <fieldset class="lf-if-fieldset">
          <legend>{{localize "LOOKFAR.ItemForge.Dialogs.ItemForge.Cost.Legend"}}</legend>
          <div id="costRow" class="lf-if-cost-row">
            <i class="fuk fu-zenit" aria-hidden="true"></i>
            <span id="costValue" class="lf-if-cost-value">0</span>
            <label class="lf-if-cost-fee">
              <input type="checkbox" id="optFee">
              <span>{{localize "LOOKFAR.ItemForge.Dialogs.ItemForge.Cost.Fee"}}</span>
            </label>
          </div>
        </fieldset>

      </div>

    </div>

    {{!-- Materials --}}
    <fieldset class="lf-if-fieldset lf-if-materials-fieldset">
      <legend>{{localize "LOOKFAR.ItemForge.Dialogs.ItemForge.Materials.Legend"}}</legend>
      <div id="materialsDrop" class="lf-if-materials-drop">
        <div id="materialsHint" class="lf-if-materials-hint">
          {{localize "LOOKFAR.ItemForge.Dialogs.ItemForge.Materials.Hint"}}
        </div>
      </div>
    </fieldset>

  </div>
</div>
