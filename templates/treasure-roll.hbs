<div id="lookfar-treasure-gen">

  <!-- Left Half of Dialog / Column 1 -->
  <div id="genOptions">

    <!-- Budget -->
    <div class="form-group lf-tr-budget-row">
      <input
        type="number"
        id="treasureBudget"
        min="1"
        placeholder='{{localize "LOOKFAR.TreasureRoll.Dialogs.TreasureRoll.Fields.Budget"}}'
        title='{{localize "LOOKFAR.TreasureRoll.Dialogs.TreasureRoll.Fields.Budget"}}'
        class="lf-tr-budget-input"
      />
    </div>

    <!-- Level -->
    <div class="form-group lf-tr-row">
      <label for="highestPCLevel" class="lf-tr-label">
        {{localize "LOOKFAR.TreasureRoll.Dialogs.TreasureRoll.Fields.Level"}}
      </label>
      <select id="highestPCLevel" class="lf-tr-select">
        <option value="500">5+</option>
        <option value="1000">10+</option>
        <option value="1500">20+</option>
        <option value="2000">30+</option>
        <option value="999999">40+</option>
      </select>
    </div>

    <!-- Origin -->
    <div class="form-group lf-tr-row">
      <label for="origin" class="lf-tr-label">
        {{localize "LOOKFAR.TreasureRoll.Dialogs.TreasureRoll.Fields.Origin"}}
      </label>
      <select id="origin" class="lf-tr-select">
        <option value="Random" selected>{{localize "LOOKFAR.TreasureRoll.Dialogs.TreasureRoll.Fields.Random"}}</option>
        <option value="Aerial">{{localize "LOOKFAR.Terms.Origin.Aerial"}}</option>
        <option value="Thunderous">{{localize "LOOKFAR.Terms.Origin.Thunderous"}}</option>
        <option value="Paradox">{{localize "LOOKFAR.Terms.Origin.Paradox"}}</option>
        <option value="Terrestrial">{{localize "LOOKFAR.Terms.Origin.Terrestrial"}}</option>
        <option value="Ardent">{{localize "LOOKFAR.Terms.Origin.Ardent"}}</option>
        <option value="Glacial">{{localize "LOOKFAR.Terms.Origin.Glacial"}}</option>
        <option value="Spiritual">{{localize "LOOKFAR.Terms.Origin.Spiritual"}}</option>
        <option value="Corrupted">{{localize "LOOKFAR.Terms.Origin.Corrupted"}}</option>
        <option value="Aquatic">{{localize "LOOKFAR.Terms.Origin.Aquatic"}}</option>
        <option value="Mechanical">{{localize "LOOKFAR.Terms.Origin.Mechanical"}}</option>
      </select>
    </div>

    <!-- Nature -->
    <div class="form-group lf-tr-row">
      <label for="nature" class="lf-tr-label">
        {{localize "LOOKFAR.TreasureRoll.Dialogs.TreasureRoll.Fields.Nature"}}
      </label>
      <select id="nature" class="lf-tr-select">
        <option value="Random" selected>{{localize "LOOKFAR.TreasureRoll.Dialogs.TreasureRoll.Fields.Random"}}</option>
        <option value="Anthropod">{{localize "LOOKFAR.Terms.Nature.Anthropod"}}</option>
        <option value="Bird">{{localize "LOOKFAR.Terms.Nature.Bird"}}</option>
        <option value="Fish">{{localize "LOOKFAR.Terms.Nature.Fish"}}</option>
        <option value="Mammal">{{localize "LOOKFAR.Terms.Nature.Mammal"}}</option>
        <option value="Mollusk">{{localize "LOOKFAR.Terms.Nature.Mollusk"}}</option>
        <option value="Reptile">{{localize "LOOKFAR.Terms.Nature.Reptile"}}</option>
        <option value="Fungus">{{localize "LOOKFAR.Terms.Nature.Fungus"}}</option>
        <option value="Incorporeal">{{localize "LOOKFAR.Terms.Nature.Incorporeal"}}</option>
        <option value="Liquid">{{localize "LOOKFAR.Terms.Nature.Liquid"}}</option>
        <option value="Artificial">{{localize "LOOKFAR.Terms.Nature.Artificial"}}</option>
        <option value="Mineral">{{localize "LOOKFAR.Terms.Nature.Mineral"}}</option>
      </select>
    </div>

    <!-- Item Count -->
    <div class="form-group lf-tr-row">
      <label for="itemCount" class="lf-tr-label">
        {{localize "LOOKFAR.TreasureRoll.Dialogs.TreasureRoll.Fields.Items"}}
      </label>
      <div class="lf-tr-count-controls">
        <button type="button" id="subCount" class="lf-tr-count-btn">−</button>
        <input
          type="number"
          id="itemCount"
          value="1"
          min="1"
          max="10"
          readonly
          class="lf-tr-count-input"
        />
        <button type="button" id="addCount" class="lf-tr-count-btn">+</button>
      </div>
    </div>

  </div>

  <!-- Right half (Columns 2 & 3) -->
  <div id="lootOptions">

    <!-- Header Options -->
    <div class="lf-tr-header-options">
      <label class="lf-tr-inline-option">
        <input type="checkbox" id="ignoreValues" />
        <small>{{localize "LOOKFAR.TreasureRoll.Dialogs.TreasureRoll.IgnoreValues"}}</small>
      </label>
      <label class="lf-tr-inline-option">
        <input type="checkbox" id="selectAllLoot" />
        <small>{{localize "LOOKFAR.TreasureRoll.Dialogs.TreasureRoll.SelectAll"}}</small>
      </label>
    </div>

    <!-- Checkbox columns -->
    <div class="lf-tr-checkbox-columns">

      <!-- Column 1 -->
      <div class="checkbox-group lf-tr-checkbox-group">
        <label class="lf-tr-checkbox-row">
          <input type="checkbox" id="includeWeapons" />
          <span>{{localize "LOOKFAR.TreasureRoll.Dialogs.TreasureRoll.ItemType.Weapon"}}</span>
        </label>
        <label class="lf-tr-checkbox-row">
          <input type="checkbox" id="includeArmor" />
          <span>{{localize "LOOKFAR.TreasureRoll.Dialogs.TreasureRoll.ItemType.Armor"}}</span>
        </label>
        <label class="lf-tr-checkbox-row">
          <input type="checkbox" id="includeAccessories" />
          <span>{{localize "LOOKFAR.TreasureRoll.Dialogs.TreasureRoll.ItemType.Accessory"}}</span>
        </label>
        <label class="lf-tr-checkbox-row">
          <input type="checkbox" id="includeShields" />
          <span>{{localize "LOOKFAR.TreasureRoll.Dialogs.TreasureRoll.ItemType.Shield"}}</span>
        </label>
      </div>

      <!-- Column 2 -->
      <div class="checkbox-group lf-tr-checkbox-group">
        <label class="lf-tr-checkbox-row">
          <input type="checkbox" id="includeMaterials" />
          <span>{{localize "LOOKFAR.TreasureRoll.Dialogs.TreasureRoll.ItemType.Material"}}</span>
        </label>
        <label class="lf-tr-checkbox-row">
          <input type="checkbox" id="includeIngredients" />
          <span>{{localize "LOOKFAR.TreasureRoll.Dialogs.TreasureRoll.ItemType.Ingredient"}}</span>
        </label>
        <label class="lf-tr-checkbox-row">
          <input type="checkbox" id="includeCurrency" />
          <span>{{localize "LOOKFAR.TreasureRoll.Dialogs.TreasureRoll.ItemType.Currency"}}</span>
        </label>
        <label class="lf-tr-checkbox-row">
          <input type="checkbox" id="includeCustom" />
          <span>{{localize "LOOKFAR.TreasureRoll.Dialogs.TreasureRoll.ItemType.Custom"}}</span>
        </label>
      </div>

    </div>
  </div>
</div>
